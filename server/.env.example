# Base de données (Supabase — pooler mode Transaction)
DATABASE_URL=postgresql://postgres.XXXX:MOT_DE_PASSE@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# Serveur
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=changer-en-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changer-aussi-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Email (SMTP Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=adresse@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Upload
UPLOAD_MAX_SIZE_MB=10

# URL de l'application
APP_URL=http://localhost:5174

# IA (si besoin)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
